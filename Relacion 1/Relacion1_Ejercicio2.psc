Algoritmo Ejercicio2
	// Calcular el perímetro y área de un rectángulo dada su base y su altura.
	
	//Datos de entrada
	Definir base Como Real 
	Escribir "Introduce la base del rectángulo en centímetros"
	Leer base
	Definir altura como Real
	Escribir "Introduce la altura del rectángulo en centímetros"
	Leer altura
	
	Definir perímetro Como Real
	perímetro<- (base+base) + (altura+altura)
	Escribir "El perímetro es " perímetro "cm"
	
	
FinAlgoritmo
